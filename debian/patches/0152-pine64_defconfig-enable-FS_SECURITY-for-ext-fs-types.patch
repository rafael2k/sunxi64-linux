From 6ffbed7ec5602df0ea36a8aab33b3f50a5b639ab Mon Sep 17 00:00:00 2001
From: Bhushan Shah <bshah@kde.org>
Date: Thu, 9 Jul 2020 17:07:35 +0530
Subject: [PATCH 152/184] pine64_defconfig: enable FS_SECURITY for ext* fs
 types

Signed-off-by: Bhushan Shah <bshah@kde.org>
---
 arch/arm64/configs/pine64_defconfig | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/arch/arm64/configs/pine64_defconfig b/arch/arm64/configs/pine64_defconfig
index 3adbd650d69e..859172669e16 100644
--- a/arch/arm64/configs/pine64_defconfig
+++ b/arch/arm64/configs/pine64_defconfig
@@ -576,8 +576,12 @@ CONFIG_TEE=y
 CONFIG_OPTEE=y
 CONFIG_VALIDATE_FS_PARSER=y
 CONFIG_EXT2_FS=y
+CONFIG_EXT2_FS_XATTR=y
+CONFIG_EXT2_FS_POSIX_ACL=y
+CONFIG_EXT2_FS_SECURITY=y
 CONFIG_EXT3_FS=y
-CONFIG_EXT4_FS_POSIX_ACL=y
+CONFIG_EXT3_FS_POSIX_ACL=y
+CONFIG_EXT3_FS_SECURITY=y
 CONFIG_BTRFS_FS=m
 CONFIG_BTRFS_FS_POSIX_ACL=y
 CONFIG_FANOTIFY=y
-- 
2.30.0

