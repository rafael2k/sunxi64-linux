From 7f72a463125673b00e10236952825b61fc3a4645 Mon Sep 17 00:00:00 2001
From: Ondrej Jirman <megous@megous.com>
Date: Mon, 30 Nov 2020 05:58:12 +0100
Subject: [PATCH 123/184] power: supply: axp20x-usb-power: Don't require exact
 values for input current limit

Available values are not enumerable, and usb type-c driver needs
to set lower or equal current limits after PD negotiation.

Signed-off-by: Ondrej Jirman <megous@megous.com>
---
 drivers/power/supply/axp20x_usb_power.c | 71 +++++++++++--------------
 1 file changed, 30 insertions(+), 41 deletions(-)

diff --git a/drivers/power/supply/axp20x_usb_power.c b/drivers/power/supply/axp20x_usb_power.c
index f1947e89ff32..74904d9ccd76 100644
--- a/drivers/power/supply/axp20x_usb_power.c
+++ b/drivers/power/supply/axp20x_usb_power.c
@@ -60,15 +60,16 @@
 #define AXP813_BC_EN		BIT(0)
 
 #define AXP813_VBUS_CLIMIT_REAL_MASK	GENMASK(7, 4)
-#define AXP813_VBUS_CLIMIT_REAL_100mA	(0 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_500mA	(1 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_900mA	(2 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_1500mA	(3 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_2000mA	(4 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_2500mA	(5 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_3000mA	(6 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_3500mA	(7 << 4)
-#define AXP813_VBUS_CLIMIT_REAL_4000mA	(8 << 4)
+#define AXP813_VBUS_CLIMIT_REAL_OFFSET	4
+#define AXP813_VBUS_CLIMIT_REAL_100mA	(0 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_500mA	(1 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_900mA	(2 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_1500mA	(3 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_2000mA	(4 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_2500mA	(5 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_3000mA	(6 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_3500mA	(7 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
+#define AXP813_VBUS_CLIMIT_REAL_4000mA	(8 << AXP813_VBUS_CLIMIT_REAL_OFFSET)
 /* The remaining values are all 4000mA according to the datasheet */
 
 /*
@@ -498,46 +499,34 @@ static int axp20x_usb_power_set_current_max(struct axp20x_usb_power *power,
 	return -EINVAL;
 }
 
+static const unsigned axp813_input_current_limits_table[] = {
+	100000,
+	500000,
+	900000,
+	1500000,
+	2000000,
+	2500000,
+	3000000,
+	3500000,
+	4000000,
+};
+
 static int axp20x_usb_power_set_input_current_limit(struct axp20x_usb_power *power,
 						    int intval)
 {
-	int val;
+	unsigned int reg;
 
-	switch (intval) {
-	case 100000:
-		val = AXP813_VBUS_CLIMIT_REAL_100mA;
-		break;
-	case 500000:
-		val = AXP813_VBUS_CLIMIT_REAL_500mA;
-		break;
-	case 900000:
-		val = AXP813_VBUS_CLIMIT_REAL_900mA;
-		break;
-	case 1500000:
-		val = AXP813_VBUS_CLIMIT_REAL_1500mA;
-		break;
-	case 2000000:
-		val = AXP813_VBUS_CLIMIT_REAL_2000mA;
-		break;
-	case 2500000:
-		val = AXP813_VBUS_CLIMIT_REAL_2500mA;
-		break;
-	case 3000000:
-		val = AXP813_VBUS_CLIMIT_REAL_3000mA;
-		break;
-	case 3500000:
-		val = AXP813_VBUS_CLIMIT_REAL_3500mA;
-		break;
-	case 4000000:
-		val = AXP813_VBUS_CLIMIT_REAL_4000mA;
-		break;
-	default:
+	if (intval < 100000)
 		return -EINVAL;
-	}
+
+	for (reg = ARRAY_SIZE(axp813_input_current_limits_table) - 1; reg > 0; reg--)
+		if (intval >= axp813_input_current_limits_table[reg])
+			break;
 
 	return regmap_update_bits(power->regmap,
 				  AXP22X_CHRG_CTRL3,
-				  AXP813_VBUS_CLIMIT_REAL_MASK, val);
+				  AXP813_VBUS_CLIMIT_REAL_MASK,
+				  reg << AXP813_VBUS_CLIMIT_REAL_OFFSET);
 }
 
 static int axp813_set_usb_bc_enabled(struct axp20x_usb_power *power, int val)
-- 
2.30.0

